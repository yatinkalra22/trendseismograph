# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_KEY_SECRET=dev-secret-change-in-production

# ─── PostgreSQL ────────────────────────────────────────
# POSTGRES_PASSWORD is required — docker-compose will fail if unset
DATABASE_URL=postgresql://postgres:your-strong-password@localhost:5432/trendseismograph
POSTGRES_DB=trendseismograph
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password

# ─── Redis ─────────────────────────────────────────────
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@localhost:6379

# ─── Python NLP Service ────────────────────────────────
NLP_SERVICE_URL=http://nlp-service:8000
NLP_SERVICE_SECRET=change-me-in-production

# ─── YouTube Data API v3 ───────────────────────────────
# Active discourse signal for the ZerveHack 2026 submission.
# Get from: https://console.cloud.google.com (enable "YouTube Data API v3", create an API key)
# Consumed by: zerve/cells/03_fetch_youtube.py
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Reddit API (dormant) ──────────────────────────────
# Reddit API access was not granted for the hackathon. The legacy NestJS
# fetcher still reads these vars if configured, but the active submission
# uses YouTube + GDELT instead. Leave as placeholders if you don't have keys.
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=TrendSeismograph/1.0 by YourRedditUsername

# ─── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=re_your_key_here
ALERT_FROM_EMAIL=alerts@trendseismograph.com

# ─── Frontend ──────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=TrendSeismograph
FRONTEND_URL=http://localhost:3000
