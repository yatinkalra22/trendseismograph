    "@nestjs/config": "^3.2.0",
    "@nestjs/bull": "^10.1.1",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs-modules/ioredis": "^2.0.2",
    "typeorm": "^0.3.20",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "bull": "^4.12.2",
    "axios": "^1.6.8",
    "helmet": "^7.1.0",
    "resend": "^3.2.0",
    "class-validator": "^0.14.1",
